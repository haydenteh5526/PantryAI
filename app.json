{
  "expo": {
    "name": "PantryAI",
    "slug": "pantryai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#52796F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pantryai.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.pantryai.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PantryAI to access your camera to scan ingredients."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PantryAI to access your photos to scan ingredients."
        }
      ],
      "expo-font",
      "@sentry/react-native"
    ],
    "scheme": "pantryai"
  }
}
