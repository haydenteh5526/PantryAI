# PantryAI Environment Variables
# Copy this file to .env and fill in your values

# Required: Supabase (create project at https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Required: Google Gemini API (free tier - https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_key_here

# Optional: OpenAI (reserved for production switch)
OPENAI_API_KEY=
